# Create a config file
# See here: https://www.youtube.com/watch?v=jWuQxU4bDeU
theme = TokyoNight Moon
# override theme optionally
config-file = ?auto/theme.ghostty
font-family = "Comic Shanns Mono"
font-size = 16.0
background-opacity = 0.9
# make more compact, like wezterm
adjust-cell-width = -10%
macos-option-as-alt = true
keybind = shift+option+B=toggle_background_opacity

