#!/usr/bin/env bash

# Create a new project under $PROJECTS, then mark the directory as trusted
# by both `pi` and `mise`.
#
# Usage: new-project [project-name]
#
# If no name is given, you are prompted for one. The directory is created
# under $PROJECTS (defaults to ~/Documents/code). The created project path
# is printed on the last line of stdout so a shell wrapper can `cd` into it
# (see the `np` function in config/bashrc).

set -euo pipefail

PROJECTS="${PROJECTS:-$HOME/Documents/code}"

# Everything informational goes to stderr so stdout stays clean for the path.
log() { printf '%s\n' "$*" >&2; }
die() {
  log "Error: $*"
  exit 1
}

name="${1:-}"
if [[ -z "${name}" ]]; then
  if [[ -r /dev/tty ]]; then
    read -r -p "Project name: " name </dev/tty
  else
    read -r -p "Project name: " name
  fi
fi
name="$(printf '%s' "${name}" | tr -d '[:space:]')"
[[ -n "${name}" ]] || die "no project name given"

case "${name}" in
*/* | .* ) die "invalid project name: ${name}" ;;
esac

dir="${PROJECTS}/${name}"
if [[ -e "${dir}" ]]; then
  die "${dir} already exists"
fi

mkdir -p "${dir}"
log "Created ${dir}"

# --- Trust the directory for mise ---
if command -v mise >/dev/null 2>&1; then
  mise trust "${dir}" >&2 || log "warning: 'mise trust' failed"
else
  log "warning: mise not found, skipping mise trust"
fi

# --- Trust the directory for pi ---
# pi persists trust decisions in ~/.pi/agent/trust.json as a path -> bool map.
trust_file="${HOME}/.pi/agent/trust.json"
mkdir -p "$(dirname "${trust_file}")"
[[ -s "${trust_file}" ]] || printf '{}\n' >"${trust_file}"
if command -v jq >/dev/null 2>&1; then
  tmp="$(mktemp)"
  jq --arg d "${dir}" '. + {($d): true}' "${trust_file}" >"${tmp}" &&
    mv "${tmp}" "${trust_file}"
  log "Trusted ${dir} for pi"
else
  log "warning: jq not found, skipping pi trust"
fi

# Emit the project path on stdout for the shell wrapper to consume.
printf '%s\n' "${dir}"
